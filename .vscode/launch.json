{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "fsq-agent: android single",
      "type": "debugpy",
      "request": "launch",
      "module": "fsq_agent.cli",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "--config",
        "config.local.yaml",
        "--task",
        "fsq-testcases/android/db/growth_could_entry_rewards_page_in_new_tab_page.codex.yaml"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "fsq-agent: android batch",
      "type": "debugpy",
      "request": "launch",
      "module": "fsq_agent.cli",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "run-batch",
        "--config",
        "config.local.yaml",
        "--tasks",
        "fsq-testcases\\android"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
