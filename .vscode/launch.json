{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "fsq-agent: android single",
      "type": "debugpy",
      "request": "launch",
      "module": "fsq_agent.cli",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "--config",
        "config.local.yaml",
        "--task",
        "fsq-testcases/android/settings/verify_that_each_item_in_the_first_part_of_l1_page_is_accessible.codex.yaml"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "fsq-agent: pre-plan",
      "type": "debugpy",
      "request": "launch",
      "module": "fsq_agent.cli",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "pre-plan",
        "--config",
        "config.local.yaml",
        "--goal",
        "Access Downloads through the browser overflow menu from the New Tab Page, then return to the New Tab Page.",
        "--format",
        "json",
        "--no-stream"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "fsq-agent: run goal",
      "type": "debugpy",
      "request": "launch",
      "module": "fsq_agent.cli",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "run-goal",
        "--config",
        "config.local.yaml",
        "--goal",
        "Access Downloads through the browser overflow menu from the New Tab Page, then return to the New Tab Page.",
        "--stream-format",
        "jsonl"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "fsq-agent: android batch",
      "type": "debugpy",
      "request": "launch",
      "module": "fsq_agent.cli",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "run-batch",
        "--config",
        "config.local.yaml",
        "--tasks",
        "fsq-testcases\\android"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "fsq-agent: android strict core",
      "type": "debugpy",
      "request": "launch",
      "module": "fsq_agent.cli",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "run-strict-core",
        "--config",
        "config.local.yaml",
        "--task",
        "fsq-testcases/android/bottom_bar/open_new_inprivate_tab_through_overflow_menu.codex.yaml",
        "--android-serial",
        "b3f60dc6"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
