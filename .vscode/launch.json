{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Auto Test Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "auto_test_agent.cli",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "--config",
        "config.local.yaml",
        "--task",
        "examples/tasks/societas-login.yaml"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
