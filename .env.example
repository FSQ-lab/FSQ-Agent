AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-api-key

# Required for android harness runs.
ANDROID_HOME=C:/android/sdk
CAPABILITIES_CONFIG=.fsq-agent-workspace/appium-capabilities.local.json

# Optional runtime secrets for account setup flows.
TEST_ACCOUNT_EMAIL=replace-with-test-account-email
TEST_ACCOUNT_PASSWORD=replace-with-test-account-password