# fsq-agent loads .env from the repository root and from the selected config file directory.
# Existing process environment variables take precedence over values in this file.

# Required only when openai_agents.provider is azure_openai.
AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-api-key

# Required only for account-dependent tasks that list these names in
# runtime_secrets.allowed_env_names. Leave blank or remove when not needed.
TEST_ACCOUNT_EMAIL=
TEST_ACCOUNT_PASSWORD=
